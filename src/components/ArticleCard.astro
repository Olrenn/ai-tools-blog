---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  heroImage?: string;
  category: string;
  rating: number;
  toolName: string;
}

const { title, description, slug, pubDate, heroImage, category, rating, toolName } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("de-DE", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const fullStars = Math.floor(rating);
const hasHalf = rating % 1 >= 0.5;
const stars = "\u2605".repeat(fullStars) + (hasHalf ? "\u2605" : "") + "\u2606".repeat(5 - fullStars - (hasHalf ? 1 : 0));
---

<article class="card group">
  <a href={`/blog/${slug}`} class="block">
    {heroImage ? (
      <div class="overflow-hidden">
        <img
          src={heroImage}
          alt={`${toolName} Review`}
          class="w-full h-52 object-cover group-hover:scale-[1.03] transition-transform duration-500 ease-out"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="w-full h-52 bg-gradient-to-br from-primary/10 to-accent/10 flex items-center justify-center">
        <span class="text-4xl font-bold text-primary/20">{toolName}</span>
      </div>
    )}
  </a>

  <div class="p-5">
    <div class="flex items-center gap-2.5 mb-3">
      <span class="badge badge-primary">{category}</span>
      <span class="stars">{stars}</span>
    </div>

    <h2 class="text-base font-bold mb-2 leading-snug group-hover:text-primary transition-colors">
      <a href={`/blog/${slug}`}>{title}</a>
    </h2>

    <p class="text-text-muted text-sm mb-4 line-clamp-2 leading-relaxed">{description}</p>

    <div class="flex items-center justify-between pt-3 border-t border-border-light">
      <time class="text-xs text-text-light" datetime={pubDate.toISOString()}>{formattedDate}</time>
      <a href={`/blog/${slug}`} class="text-sm text-primary font-semibold hover:text-primary-dark transition-colors flex items-center gap-1">
        Lesen
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
