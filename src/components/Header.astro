---
const navItems = [
  { href: "/", label: "Start" },
  { href: "/blog", label: "Blog" },
  { href: "/tools", label: "Tools" },
  { href: "/about", label: "Über uns" },
];
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-border">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-xl font-bold text-primary">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2L2 7l10 5 10-5-10-5z" />
        <path d="M2 17l10 5 10-5" />
        <path d="M2 12l10 5 10-5" />
      </svg>
      KI-Tools Vergleich
    </a>

    <ul class="hidden md:flex items-center gap-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-text-muted hover:text-primary transition-colors text-sm font-medium"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
