---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="my-8 grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="p-5 bg-green-50 border border-green-200 rounded-xl">
    <h3 class="font-bold text-green-800 mb-3 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 6L9 17l-5-5" />
      </svg>
      Vorteile
    </h3>
    <ul class="space-y-2">
      {pros.map((pro) => (
        <li class="flex items-start gap-2 text-sm text-green-900">
          <span class="text-green-500 mt-0.5">+</span>
          {pro}
        </li>
      ))}
    </ul>
  </div>

  <div class="p-5 bg-red-50 border border-red-200 rounded-xl">
    <h3 class="font-bold text-red-800 mb-3 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
      Nachteile
    </h3>
    <ul class="space-y-2">
      {cons.map((con) => (
        <li class="flex items-start gap-2 text-sm text-red-900">
          <span class="text-red-500 mt-0.5">-</span>
          {con}
        </li>
      ))}
    </ul>
  </div>
</div>
